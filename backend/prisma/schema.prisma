// ─── MATCH LOG (Personal player journal) ────────────────────────────────
//
// Each player can keep their own private journal of matches.
// Three flavours, all stored in this single table:
//   1) Standalone — the match was played off-platform (organiser doesn't use
//      pelotitas). Owner records score + opponents (registered or by name) +
//      notes. Score lives directly on the entry.
//   2) Linked to a pickup Match — owner adds private notes/score on a Match
//      that exists in the platform.
//   3) Linked to a TournamentMatch — owner adds private notes only. Score
//      fields are ignored; the truth lives in TournamentMatchSet (set by org).
//
// Phantom opponents (not on pelotitas yet): stored on MatchLogParticipant by
// firstName + lastName. When that person registers and claims the records,
// userId gets backfilled.

model MatchLogEntry {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("MatchLogOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // ─── Optional linkage (at most one of these) ───
  matchId           String?
  match             Match?           @relation(fields: [matchId], references: [id], onDelete: SetNull)
  tournamentMatchId String?
  tournamentMatch   TournamentMatch? @relation(fields: [tournamentMatchId], references: [id], onDelete: SetNull)

  // ─── Standalone fields (used when no link) ───
  sport     Sport
  date      DateTime @db.Date
  startTime String? // "HH:MM"
  city      String?
  venue     String? // freeform: "Club Almagro", etc.

  // ─── Score (writable when not linked to a TournamentMatch) ───
  myScore       String? // freeform "6-4 6-3" or structured later
  opponentScore String?
  result        MatchOutcome?

  // ─── Private notes ───
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants MatchLogParticipant[]

  @@index([ownerId, date])
  @@index([matchId])
  @@index([tournamentMatchId])
  @@map("match_log_entries")
}

// ─── SCOREBOARD (Live point-by-point scorer) ───────────────────────────
//
// Two flavours, same model:
//   1) Official — owned by an organiser, tied to a TournamentMatch. Becomes
//      the source of truth for the tournament's TournamentMatchSet rows.
//   2) Personal — any user can score their own match. May "mirror" an
//      official scoreboard so the user can compare/copy values into their
//      own private tracker.
//
// Every point/setting change is logged as a ScoreboardEvent for full audit.

model Scoreboard {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("ScoreboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // ─── Linkage (mutually exclusive when isOfficial = true) ───
  tournamentMatchId String?
  tournamentMatch   TournamentMatch? @relation(fields: [tournamentMatchId], references: [id], onDelete: SetNull)

  // Personal scoreboards may mirror an official one so the user can copy state.
  mirrorsScoreboardId String?
  mirrorsScoreboard   Scoreboard?  @relation("ScoreboardMirror", fields: [mirrorsScoreboardId], references: [id], onDelete: SetNull)
  mirroredBy          Scoreboard[] @relation("ScoreboardMirror")

  // ─── Identity ───
  isOfficial Boolean @default(false)
  sport      Sport
  homeLabel  String // "Diego / Juan" or single name
  awayLabel  String

  // ─── Settings (mutable while in progress) ───
  scoringMode         ScoringMode @default(STANDARD)
  totalSets           Int         @default(3) // 3 = bo3, 5 = bo5
  gamesPerSet         Int         @default(6) // typically 6
  tieBreakAt          Int         @default(6) // 6-6 → tiebreak
  superTieBreak       Boolean     @default(false) // last "set" is a super tiebreak (to 10)
  tieBreakPoints      Int         @default(7)
  superTieBreakPoints Int         @default(10)

  // ─── Live state ───
  status          ScoreboardStatus @default(IN_PROGRESS)
  currentSet      Int              @default(1)
  homeSetGames    Int[]            @default([]) // games won per set, e.g. [6, 4]
  awaySetGames    Int[]            @default([])
  homePoints      Int              @default(0) // 0..3 within a game
  awayPoints      Int              @default(0)
  homeAdvantage   Boolean          @default(false)
  awayAdvantage   Boolean          @default(false)
  inTieBreak      Boolean          @default(false)
  inSuperTieBreak Boolean          @default(false)
  homeTbPoints    Int              @default(0)
  awayTbPoints    Int              @default(0)
  servingSide     ScoreboardSide   @default(HOME)
  winner          ScoreboardSide?
  finishedAt      DateTime?

  // ─── Personal notes attached to this scoreboard ───
  notes String?

  events ScoreboardEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, tournamentMatchId])
  @@index([ownerId])
  @@index([tournamentMatchId])
  @@index([status])
  @@map("scoreboards")
}

model ScoreboardEvent {
  id           String     @id @default(cuid())
  scoreboardId String
  scoreboard   Scoreboard @relation(fields: [scoreboardId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation("ScoreboardEventAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  // Action taxonomy: POINT_HOME, POINT_AWAY, UNDO, GAME_HOME, GAME_AWAY,
  // SET_HOME, SET_AWAY, SETTING_CHANGE, COPY_FROM_OFFICIAL, RESET, COMPLETE.
  action       String
  payload      Json? // freeform — settings diff, prior state for undo, etc.
  createdAt    DateTime   @default(now())

  @@index([scoreboardId, createdAt])
  @@index([authorId])
  @@map("scoreboard_events")
}

model MatchLogParticipant {
  id      String        @id @default(cuid())
  entryId String
  entry   MatchLogEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // Either a registered user…
  userId    String?
  user      User?   @relation("MatchLogParticipantUser", fields: [userId], references: [id], onDelete: SetNull)
  // …or a phantom — stored as free text and later linkable.
  firstName String?
  lastName  String?

  side            MatchLogSide // PARTNER | OPPONENT
  noteAboutPlayer String?

  createdAt DateTime @default(now())

  @@index([entryId])
  @@index([userId])
  @@index([firstName, lastName])
  @@map("match_log_participants")
}
