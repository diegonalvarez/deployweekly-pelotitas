generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum UserRole {
  PLAYER
  COACH
  CLUB_OWNER
  TOURNAMENT_ORGANIZER
  ADMIN
}

enum Sport {
  PADEL
  TENNIS
}

enum HandPreference {
  LEFT
  RIGHT
  AMBIDEXTROUS
}

enum CourtSurface {
  CLAY
  HARD
  GRASS
  SYNTHETIC
  CONCRETE
  CARPET
}

enum CourtType {
  INDOOR
  OUTDOOR
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum CourtStatus {
  AVAILABLE
  RESERVED
  BLOCKED
  MAINTENANCE
}

enum ReservationAccessMode {
  OPEN // Any verified user can reserve
  CONNECTED_ONLY // Only connected/friend users can reserve
}

enum CoachClubStatus {
  INVITED
  REQUESTED
  ACTIVE
  INACTIVE
  REJECTED
}

enum BookingType {
  INDIVIDUAL
  GROUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MatchStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  GROUP_STAGE
  ELIMINATION
  COMPLETED
  CANCELLED
}

enum TournamentMatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  WALKOVER
  CANCELLED
}

enum BracketRound {
  ROUND_OF_64
  ROUND_OF_32
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  FINAL
}

enum ConnectionType {
  PLAYER_CLUB // Player wants to reserve at club
  PLAYER_COACH // Player wants classes with coach
  ORGANIZER_CLUB // Organizer wants to run tournaments at club
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum ClubApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum IdentityStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum NotificationType {
  REGISTRATION
  RESERVATION_CREATED
  RESERVATION_CANCELLED
  RESERVATION_REMINDER
  CLASS_BOOKED
  CLASS_PRE_APPROVED
  CLASS_APPROVED
  COACH_INVITED
  COACH_ACCEPTED
  COACH_REJECTED
  TOURNAMENT_REGISTERED
  MATCH_SCHEDULED
  FIXTURE_CHANGED
  RESULT_UPLOADED
  MATCH_INVITATION
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  CONNECTION_REJECTED
  CLUB_APPROVED
  CLUB_REJECTED
  CHALLENGE_RECEIVED
  WAITLIST_AVAILABLE
  OTP_CODE
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
  READ
}

enum MatchOutcome {
  WON
  LOST
  DRAW
}

enum MatchLogSide {
  PARTNER // mi compañero / mi equipo
  OPPONENT // rival
}

enum ScoringMode {
  STANDARD // 0/15/30/40 with deuce + advantage
  GOLDEN_POINT // sudden death at deuce (point of gold)
}

enum ScoreboardStatus {
  IN_PROGRESS
  PAUSED
  COMPLETED
  ABANDONED
}

enum ScoreboardSide {
  HOME
  AWAY
}

// Mirrors Stripe subscription statuses we care about. Anything else is mapped to INACTIVE.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  INACTIVE
}

// ─── USERS & AUTH ───────────────────────────────────────

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  passwordHash    String? // Null when using Google OAuth only
  firstName       String
  lastName        String
  phone           String?      @unique
  avatarUrl       String?
  roles           UserRole[]   @default([]) // Empty until user activates profiles
  isActive        Boolean      @default(true)
  emailVerified   Boolean      @default(false)
  phoneVerified   Boolean      @default(false)
  termsAcceptedAt DateTime? // When user accepted T&C
  authProvider    AuthProvider @default(LOCAL)
  googleId        String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  // Identity verification
  identityStatus     IdentityStatus @default(NOT_STARTED)
  identityDocUrl     String? // Encrypted reference to DNI scan
  identityVerifiedAt DateTime?

  // OTP
  otpCode      String?
  otpExpiresAt DateTime?

  // Profiles (activated on demand)
  playerProfile    PlayerProfile?
  coachProfile     CoachProfile?
  clubProfiles     ClubProfile[]
  organizerProfile OrganizerProfile?
  subscription     Subscription?

  // Relations
  reservations            Reservation[]
  coachBookings           CoachBooking[]           @relation("StudentBookings")
  matchParticipants       MatchParticipant[]
  tournamentPlayers       TournamentTeamPlayer[]
  notifications           Notification[]
  createdMatches          Match[]
  createdTournaments      Tournament[]
  auditLogs               AuditLog[]
  sentConnections         Connection[]             @relation("ConnectionFrom")
  receivedConnections     Connection[]             @relation("ConnectionTo")
  sentChallenges          Challenge[]              @relation("ChallengerUser")
  receivedChallenges      Challenge[]              @relation("ChallengedUser")
  coachReviewsWritten     CoachStudentReview[]     @relation("ReviewAuthor")
  coachReviewsReceived    CoachStudentReview[]     @relation("ReviewSubject")
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  recurringReservations   RecurringReservation[]
  waitlistEntries         Waitlist[]
  achievements            UserAchievement[]
  feedItems               ActivityFeedItem[]
  xpPoints                Int                      @default(0)
  matchLogEntries         MatchLogEntry[]          @relation("MatchLogOwner")
  matchLogParticipations  MatchLogParticipant[]    @relation("MatchLogParticipantUser")
  scoreboards             Scoreboard[]             @relation("ScoreboardOwner")
  scoreboardEvents        ScoreboardEvent[]        @relation("ScoreboardEventAuthor")
  eloRatings              EloRating[]              @relation("UserEloRatings")
  reservationJoins        ReservationJoin[]        @relation("ReservationJoiner")

  @@index([email])
  @@index([phone])
  @@index([googleId])
  @@map("users")
}

// ─── ELO ratings — one row per (user, sport) ─────────────────────────
// Recalculated whenever a Scoreboard transitions to COMPLETED with a
// known winner. Default starting rating is 1000; K-factor is 32 while
// matchesCount < 30 (provisional), 16 afterwards.

model EloRating {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserEloRatings", fields: [userId], references: [id], onDelete: Cascade)
  sport        Sport
  rating       Int      @default(1000)
  peakRating   Int      @default(1000)
  matchesCount Int      @default(0)
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  lastMatchAt  DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([userId, sport])
  @@index([sport, rating])
  @@map("elo_ratings")
}

// ─── PROFILES ───────────────────────────────────────────

model PlayerProfile {
  id                       String          @id @default(cuid())
  userId                   String          @unique
  user                     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Legacy single-location fields (kept for back-compat with existing rows).
  // New code should write to home* and current* fields below.
  city                     String?
  state                    String?
  // Home — where the player is from
  homeCountry              String?
  homeState                String?
  homeCity                 String?
  // Current location — where the player is right now (may differ from home).
  // Used for proximity discovery, "available now", and travelling players.
  currentCountry           String?
  currentState             String?
  currentCity              String?
  currentLatitude          Float?
  currentLongitude         Float?
  currentLocationUpdatedAt DateTime?
  bio                      String?
  hand                     HandPreference?
  sports                   Sport[]         @default([])
  padelLevel               Float? // 1.0 - 10.0
  tennisLevel              Float? // 1.0 - 10.0
  padelCategory            String? // "4ta", "5ta", "6ta", "7ma", "8va", "Open", etc.
  tennisCategory           String?
  preferredPosition        String? // Drive/Revés for padel
  showPhoneToOrganizers    Boolean         @default(false) // Allow organizers to see phone
  matchesPlayed            Int             @default(0)
  matchesWon               Int             @default(0)
  matchesLost              Int             @default(0)
  setsWon                  Int             @default(0)
  setsLost                 Int             @default(0)
  gamesWon                 Int             @default(0)
  gamesLost                Int             @default(0)

  // Availability ("Estoy disponible ahora")
  isAvailableNow Boolean   @default(false)
  availableUntil DateTime?
  availableSport Sport?

  // Privacy controls (all default PUBLIC = true)
  showStats        Boolean @default(true)
  showMatchHistory Boolean @default(true)
  showLevel        Boolean @default(true)
  showCity         Boolean @default(true)
  showAvailability Boolean @default(true)
  showTournaments  Boolean @default(true)

  // Ranking (calculated)
  rankingPoints   Int  @default(0)
  rankingPosition Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([homeCity])
  @@index([homeCountry])
  @@index([currentCity])
  @@index([currentCountry])
  @@index([currentLatitude, currentLongitude])
  @@index([padelCategory])
  @@index([tennisCategory])
  @@index([isAvailableNow])
  @@index([rankingPoints])
  @@map("player_profiles")
}

model CoachProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?
  sports            Sport[]  @default([])
  experience        String?
  certifications    String?
  pricePerHour      Float?
  groupPrice        Float?
  isPublic          Boolean  @default(true)
  requireConnection Boolean  @default(true) // Only connected players can book
  autoAcceptAll     Boolean  @default(false) // Auto-accept bookings from all connected
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clubLinks      CoachClubLink[]
  availabilities CoachAvailability[]
  bookings       CoachBooking[]
  reviews        CoachStudentReview[]
  autoAcceptList CoachAutoAccept[]

  @@map("coach_profiles")
}

// ─── BILLING / SUBSCRIPTIONS ───────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe identifiers — null until first checkout completes
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  // Plan slug we expose to the client (e.g. "pro_monthly", "pro_annual").
  plan                 String?

  status             SubscriptionStatus @default(INACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  canceledAt         DateTime?
  trialEnd           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model OrganizerProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                  String?
  freeTournamentsUsed  Int      @default(0)
  freeTournamentsLimit Int      @default(5) // Can be increased via referrals
  referralCount        Int      @default(0) // Users brought to the platform
  referralCode         String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("organizer_profiles")
}

// ─── CONNECTIONS (Social Graph) ─────────────────────────

model Connection {
  id          String           @id @default(cuid())
  fromUserId  String
  fromUser    User             @relation("ConnectionFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String // The target user (club owner, coach, etc.)
  toUser      User             @relation("ConnectionTo", fields: [toUserId], references: [id], onDelete: Cascade)
  type        ConnectionType
  status      ConnectionStatus @default(PENDING)
  // Context: which entity this connection relates to
  clubId      String? // For PLAYER_CLUB and ORGANIZER_CLUB
  coachId     String? // For PLAYER_COACH (coachProfile id)
  message     String?
  respondedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([fromUserId, toUserId, type, clubId, coachId])
  @@index([toUserId, type, status])
  @@index([fromUserId, type])
  @@map("connections")
}

// Coach auto-accept per connected player
model CoachAutoAccept {
  id        String       @id @default(cuid())
  coachId   String
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  playerId  String // userId of the player
  createdAt DateTime     @default(now())

  @@unique([coachId, playerId])
  @@map("coach_auto_accepts")
}

// Coach private review of student (admin-visible only)
model CoachStudentReview {
  id        String       @id @default(cuid())
  coachId   String
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  authorId  String
  author    User         @relation("ReviewAuthor", fields: [authorId], references: [id])
  studentId String
  student   User         @relation("ReviewSubject", fields: [studentId], references: [id])
  comment   String
  isWarning Boolean      @default(false) // Flag for problematic student
  createdAt DateTime     @default(now())

  @@index([studentId])
  @@index([coachId])
  @@map("coach_student_reviews")
}

// ─── CLUBS & LOCATIONS ─────────────────────────────────

model ClubProfile {
  id              String                @id @default(cuid())
  ownerId         String
  owner           User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  imageUrl        String? // Main photo of the club
  sports          Sport[]               @default([])
  approvalStatus  ClubApprovalStatus    @default(PENDING)
  approvedAt      DateTime?
  rejectionReason String?
  reservationMode ReservationAccessMode @default(OPEN)
  paymentMethods  String[]              @default([]) // "cash", "transfer", "mercadopago"
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  locations   ClubLocation[]
  courts      Court[]
  coachLinks  CoachClubLink[]
  tournaments Tournament[]

  @@index([ownerId])
  @@index([approvalStatus])
  @@map("club_profiles")
}

model ClubLocation {
  id        String      @id @default(cuid())
  clubId    String
  club      ClubProfile @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name      String
  address   String
  city      String
  state     String?
  country   String      @default("Argentina")
  latitude  Float?
  longitude Float?
  phone     String?
  isMain    Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  courts Court[]

  @@index([city])
  @@index([clubId])
  @@index([latitude, longitude])
  @@map("club_locations")
}

// ─── COURTS ────────────────────────────────────────────

model Court {
  id            String        @id @default(cuid())
  clubId        String
  club          ClubProfile   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  locationId    String?
  location      ClubLocation? @relation(fields: [locationId], references: [id])
  name          String
  sport         Sport
  surface       CourtSurface
  courtType     CourtType
  hasLighting   Boolean       @default(false)
  isActive      Boolean       @default(true)
  pricePerBlock Float?
  blockDuration Int           @default(60) // minutes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  availabilities        CourtAvailability[]
  reservations          Reservation[]
  tournamentMatches     TournamentMatch[]
  matches               Match[]
  recurringReservations RecurringReservation[]
  waitlistEntries       Waitlist[]

  @@index([clubId])
  @@index([sport])
  @@map("courts")
}

model CourtAvailability {
  id        String      @id @default(cuid())
  courtId   String
  court     Court       @relation(fields: [courtId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String
  closeTime String
  status    CourtStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([courtId, dayOfWeek])
  @@map("court_availabilities")
}

// ─── RESERVATIONS ──────────────────────────────────────

model Reservation {
  id          String            @id @default(cuid())
  courtId     String
  court       Court             @relation(fields: [courtId], references: [id])
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  date        DateTime          @db.Date
  startTime   String
  endTime     String
  status      ReservationStatus @default(PENDING)
  sport       Sport
  notes       String?
  price       Float?
  paidAt      DateTime?
  cancelledAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // ─── Matchmaking — "I have a court, looking for players" ───
  openForJoin   Boolean @default(false)
  slotsNeeded   Int     @default(0) // how many more players the owner needs
  joinLevelMin  String? // optional level/category filter — freeform "B", "3.0", etc.
  joinLevelMax  String?
  joinNote      String?
  joiners       ReservationJoin[]

  @@index([courtId, date])
  @@index([userId])
  @@index([status])
  @@index([openForJoin, date])
  @@map("reservations")
}

// ─── Players joining an open reservation slot ──────────────────────
model ReservationJoin {
  id            String              @id @default(cuid())
  reservationId String
  reservation   Reservation         @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  userId        String
  user          User                @relation("ReservationJoiner", fields: [userId], references: [id], onDelete: Cascade)
  status        ReservationJoinStatus @default(PENDING)
  message       String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([reservationId, userId])
  @@index([userId])
  @@index([reservationId, status])
  @@map("reservation_joins")
}

enum ReservationJoinStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

// ─── COACHES ───────────────────────────────────────────

model CoachClubLink {
  id        String          @id @default(cuid())
  coachId   String
  coach     CoachProfile    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  clubId    String
  club      ClubProfile     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  status    CoachClubStatus @default(INVITED)
  message   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([coachId, clubId])
  @@index([clubId])
  @@map("coach_club_links")
}

model CoachAvailability {
  id        String       @id @default(cuid())
  coachId   String
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  clubId    String?
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([coachId, clubId])
  @@map("coach_availabilities")
}

model CoachBooking {
  id          String        @id @default(cuid())
  coachId     String
  coach       CoachProfile  @relation(fields: [coachId], references: [id])
  studentId   String
  student     User          @relation("StudentBookings", fields: [studentId], references: [id])
  clubId      String?
  date        DateTime      @db.Date
  startTime   String
  endTime     String
  type        BookingType   @default(INDIVIDUAL)
  status      BookingStatus @default(PENDING)
  sport       Sport
  price       Float?
  notes       String?
  cancelledAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([coachId, date])
  @@index([studentId])
  @@map("coach_bookings")
}

// ─── MATCHES & SOCIAL ──────────────────────────────────

model Match {
  id          String      @id @default(cuid())
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  courtId     String?
  court       Court?      @relation(fields: [courtId], references: [id])
  sport       Sport
  date        DateTime    @db.Date
  startTime   String
  endTime     String?
  maxPlayers  Int         @default(4)
  level       Float?
  city        String?
  description String?
  isPublic    Boolean     @default(true)
  status      MatchStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  participants MatchParticipant[]
  results      MatchResult[]
  logEntries   MatchLogEntry[]

  @@index([sport, status])
  @@index([city])
  @@index([date])
  @@map("matches")
}

model MatchParticipant {
  id       String   @id @default(cuid())
  matchId  String
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  team     Int?
  joinedAt DateTime @default(now())

  @@unique([matchId, userId])
  @@map("match_participants")
}

model MatchResult {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber  Int
  team1Score Int
  team2Score Int
  createdAt  DateTime @default(now())

  @@unique([matchId, setNumber])
  @@map("match_results")
}

// ─── CHALLENGES ────────────────────────────────────────

model Challenge {
  id           String           @id @default(cuid())
  challengerId String
  challenger   User             @relation("ChallengerUser", fields: [challengerId], references: [id])
  challengedId String
  challenged   User             @relation("ChallengedUser", fields: [challengedId], references: [id])
  sport        Sport
  message      String?
  proposedDate DateTime?        @db.Date
  proposedTime String?
  status       ConnectionStatus @default(PENDING) // reuse: PENDING/ACCEPTED/REJECTED
  matchId      String? // Links to match once accepted and created
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([challengedId, status])
  @@index([challengerId])
  @@map("challenges")
}

// ─── TOURNAMENTS ───────────────────────────────────────

model Tournament {
  id                String           @id @default(cuid())
  clubId            String
  club              ClubProfile      @relation(fields: [clubId], references: [id])
  createdById       String
  createdBy         User             @relation(fields: [createdById], references: [id])
  name              String
  description       String?
  sport             Sport
  status            TournamentStatus @default(DRAFT)
  maxTeams          Int?
  startDate         DateTime?        @db.Date
  endDate           DateTime?        @db.Date
  registrationEnd   DateTime?
  pointsPerWin      Int              @default(3)
  pointsPerLoss     Int              @default(0)
  pointsPerWalkover Int              @default(1)
  tiebreakers       String[]         @default(["POINTS", "SET_DIFF", "GAME_DIFF", "HEAD_TO_HEAD"])
  rules             String?
  isFree            Boolean          @default(true)
  isBillable        Boolean          @default(false) // Should we charge for this one?

  // ─── Match format ─── (passed to official Scoreboard when created)
  matchBestOf        Int     @default(3) // 1 | 3 | 5
  matchGamesPerSet   Int     @default(6)
  matchTieBreakAt    Int     @default(6) // 0 = no tiebreak
  matchTieBreakPts   Int     @default(7)
  matchSuperTbAtLast Boolean @default(false) // Replace last set with super TB to 10
  matchSuperTbPts    Int     @default(10)
  matchGoldenPoint   Boolean @default(false) // Padel-style sudden death on deuce
  matchProSetTo      Int? // If set, play one pro-set to N games instead of bestOf

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  categories TournamentCategory[]
  teams      TournamentTeam[]
  groups     TournamentGroup[]
  matches    TournamentMatch[]
  brackets   TournamentBracket[]

  @@index([clubId])
  @@index([sport, status])
  @@index([createdById])
  @@map("tournaments")
}

model TournamentCategory {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  maxTeams     Int?
  createdAt    DateTime   @default(now())

  teams    TournamentTeam[]
  groups   TournamentGroup[]
  brackets TournamentBracket[]

  @@map("tournament_categories")
}

model TournamentTeam {
  id           String              @id @default(cuid())
  tournamentId String
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     TournamentCategory? @relation(fields: [categoryId], references: [id])
  name         String
  seed         Int?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  players      TournamentTeamPlayer[]
  groupMembers TournamentGroupMember[]
  homeMatches  TournamentMatch[]       @relation("HomeTeam")
  awayMatches  TournamentMatch[]       @relation("AwayTeam")
  wonMatches   TournamentMatch[]       @relation("WinnerTeam")
  homeBrackets TournamentBracket[]     @relation("BracketHome")
  awayBrackets TournamentBracket[]     @relation("BracketAway")
  wonBrackets  TournamentBracket[]     @relation("BracketWinner")

  @@index([tournamentId])
  @@map("tournament_teams")
}

model TournamentTeamPlayer {
  id     String         @id @default(cuid())
  teamId String
  team   TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User           @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("tournament_team_players")
}

model TournamentGroup {
  id           String              @id @default(cuid())
  tournamentId String
  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     TournamentCategory? @relation(fields: [categoryId], references: [id])
  name         String
  qualifyCount Int                 @default(2)
  isFinalized  Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  members TournamentGroupMember[]
  matches TournamentMatch[]

  @@index([tournamentId])
  @@map("tournament_groups")
}

model TournamentGroupMember {
  id             String          @id @default(cuid())
  groupId        String
  group          TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teamId         String
  team           TournamentTeam  @relation(fields: [teamId], references: [id])
  position       Int?
  points         Int             @default(0)
  matchesPlayed  Int             @default(0)
  matchesWon     Int             @default(0)
  matchesLost    Int             @default(0)
  matchesDrawn   Int             @default(0)
  setsWon        Int             @default(0)
  setsLost       Int             @default(0)
  gamesWon       Int             @default(0)
  gamesLost      Int             @default(0)
  isQualified    Boolean         @default(false)
  manualOverride Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([groupId, teamId])
  @@map("tournament_group_members")
}

model TournamentMatch {
  id           String                @id @default(cuid())
  tournamentId String
  tournament   Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groupId      String?
  group        TournamentGroup?      @relation(fields: [groupId], references: [id])
  bracketId    String?
  bracket      TournamentBracket?    @relation(fields: [bracketId], references: [id])
  homeTeamId   String?
  homeTeam     TournamentTeam?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   String?
  awayTeam     TournamentTeam?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerId     String?
  winner       TournamentTeam?       @relation("WinnerTeam", fields: [winnerId], references: [id])
  courtId      String?
  court        Court?                @relation(fields: [courtId], references: [id])
  scheduledAt  DateTime?
  status       TournamentMatchStatus @default(SCHEDULED)
  isWalkover   Boolean               @default(false)
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  sets        TournamentMatchSet[]
  logEntries  MatchLogEntry[]
  scoreboards Scoreboard[]

  @@index([tournamentId])
  @@index([groupId])
  @@index([bracketId])
  @@map("tournament_matches")
}

model TournamentMatchSet {
  id        String          @id @default(cuid())
  matchId   String
  match     TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber Int
  homeScore Int
  awayScore Int

  @@unique([matchId, setNumber])
  @@map("tournament_match_sets")
}

model TournamentBracket {
  id            String              @id @default(cuid())
  tournamentId  String
  tournament    Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      TournamentCategory? @relation(fields: [categoryId], references: [id])
  round         BracketRound
  position      Int
  homeTeamId    String?
  homeTeam      TournamentTeam?     @relation("BracketHome", fields: [homeTeamId], references: [id])
  awayTeamId    String?
  awayTeam      TournamentTeam?     @relation("BracketAway", fields: [awayTeamId], references: [id])
  winnerId      String?
  winner        TournamentTeam?     @relation("BracketWinner", fields: [winnerId], references: [id])
  isBye         Boolean             @default(false)
  isLocked      Boolean             @default(false)
  nextBracketId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  matches TournamentMatch[]

  @@index([tournamentId, round])
  @@map("tournament_brackets")
}

// ─── NOTIFICATIONS ─────────────────────────────────────

model Notification {
