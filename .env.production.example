# ╭─────────────────────────────────────────────────────────────────╮
# │ Production env template. Copy to .env.production on the EC2     │
# │ instance and fill in real values. NEVER commit .env.production. │
# ╰─────────────────────────────────────────────────────────────────╯

# ─── Database (AWS RDS PostgreSQL) ────────────────────────────────
# Get the endpoint from the RDS console. Format:
#   postgresql://<user>:<password>@<endpoint>:5432/<db_name>?schema=public
# If your RDS requires SSL (default for new instances), append:
#   ?schema=public&sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@your-rds-endpoint.amazonaws.com:5432/pelotitas?schema=public&sslmode=require

# ─── JWT secrets (generate fresh ones for production) ─────────────
# Suggested: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_long_random_string_different
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Ports ────────────────────────────────────────────────────────
BACKEND_PORT=3099
FRONTEND_PORT=3098

# ─── Public URLs ──────────────────────────────────────────────────
# What the browser hits. Use your real domain once DNS + TLS are wired:
#   NEXT_PUBLIC_API_URL=https://api.pelotitas.com
# For an EC2-only setup with no domain yet, use the EC2 public DNS + port:
#   NEXT_PUBLIC_API_URL=http://ec2-X-X-X-X.compute-1.amazonaws.com:3099
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# CORS allowlist for the backend. Comma-separated origins (no trailing slash).
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─── Feature flags ────────────────────────────────────────────────
FREE_TOURNAMENTS_PER_OWNER=5
ENABLE_PAYMENTS=false
ENABLE_WHATSAPP=false
